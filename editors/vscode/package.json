{
  "name": "vscode-perl-lsp",
  "displayName": "Perl (perl-lsp)",
  "description": "Perl IntelliSense — autocomplete, go-to-definition, hover, and project-wide cross-file rename. Type inference and framework intelligence (Moo/Moose, Mojolicious, DBIx::Class), powered by tree-sitter-perl.",
  "version": "0.5.0",
  "publisher": "tree-sitter-perl",
  "license": "Artistic-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tree-sitter-perl/perl-tree-sitter-lsp"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "perl",
    "perl language server",
    "intellisense",
    "autocomplete",
    "rename",
    "lsp",
    "perltidy",
    "go to definition",
    "moose",
    "mojolicious",
    "dbic",
    "tree-sitter"
  ],
  "activationEvents": [
    "onLanguage:perl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Perl LSP",
      "properties": {
        "perl-lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to perl-lsp binary. Leave empty to use bundled or auto-downloaded binary."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run typecheck && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
